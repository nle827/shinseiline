<!-- HERO STAGE -->
<div class="hero-stage">

  <!-- City clock: Los Angeles -->
  <div class="city-clock" id="clock-los">
    <svg class="clock-face" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1"/>
      <line class="clock-hand-h" x1="24" y1="24" x2="24" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line class="clock-hand-m" x1="24" y1="24" x2="24" y2="7"  stroke="currentColor" stroke-width="1"   stroke-linecap="round"/>
      <line class="clock-hand-s" x1="24" y1="24" x2="24" y2="5"  stroke="currentColor" stroke-width="0.5" stroke-linecap="round"/>
      <circle cx="24" cy="24" r="1.5" fill="currentColor"/>
    </svg>
    <span class="city-clock-label">LOS</span>
    <span class="city-clock-time" id="time-los"></span>
    <span class="city-clock-date" id="date-los"></span>
  </div>

  <!-- HERO -->
  <section class="hero">
    <img class="hero-mobile-img" src="{{ 'Gemini_Generated_Image_ooyxwbooyxwbooyx.png' | asset_url }}" alt="Kagemi" aria-hidden="true">
    <div class="hero-overlay-text">
      <h1 class="hero-heading">KAGEMI</h1>
      <div class="hero-overlay-rule" aria-hidden="true"></div>
      <p class="hero-subline">LINE 01 / LONG OVERCOAT / SS26</p>
    </div>
  </section>

  <!-- City clock: Tokyo -->
  <div class="city-clock" id="clock-tyo">
    <svg class="clock-face" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1"/>
      <line class="clock-hand-h" x1="24" y1="24" x2="24" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line class="clock-hand-m" x1="24" y1="24" x2="24" y2="7"  stroke="currentColor" stroke-width="1"   stroke-linecap="round"/>
      <line class="clock-hand-s" x1="24" y1="24" x2="24" y2="5"  stroke="currentColor" stroke-width="0.5" stroke-linecap="round"/>
      <circle cx="24" cy="24" r="1.5" fill="currentColor"/>
    </svg>
    <span class="city-clock-label">TYO</span>
    <span class="city-clock-time" id="time-tyo"></span>
    <span class="city-clock-date" id="date-tyo"></span>
  </div>

</div><!-- /.hero-stage -->

<!-- LINE SELECTOR -->
<div class="line-selector" role="tablist" aria-label="Select a line">
  <div class="line-selector-inner">

    <div class="ls-track" aria-hidden="true">
      <div class="ls-track-fill"></div>
    </div>

    <!-- Node: SHOT 01 -->
    <button class="ls-node ls-node--active" role="tab" aria-selected="true" data-line="01" data-name="KAGEMI" data-sub="LINE 01 / LONG OVERCOAT / SS26" data-img="{{ 'kagemi mockup.png' | asset_url }}" data-hero="{{ 'Gemini_Generated_Image_ooyxwbooyxwbooyx.png' | asset_url }}" data-hero-mobile="{{ 'Gemini_Generated_Image_ooyxwbooyxwbooyx.png' | asset_url }}">
      <div class="ls-node-ring" aria-hidden="true"></div>
      <div class="ls-node-dot" aria-hidden="true"></div>
      <div class="ls-node-label">
        <span class="ls-node-id">01</span>
        <span class="ls-node-name">KAGEMI</span>
      </div>
    </button>

    <div class="ls-chevron" aria-hidden="true">»</div>

    <!-- Node: SHOT 02 -->
    <button class="ls-node" role="tab" aria-selected="false" data-line="02" data-name="KAGEMI" data-sub="LINE 01 / CONSTRUCTION / FRONT" data-img="{{ 'AI MOCKUP.png' | asset_url }}" data-hero="{{ 'AI MOCKUP.png' | asset_url }}" data-hero-mobile="{{ 'AI MOCKUP.png' | asset_url }}">
      <div class="ls-node-dot" aria-hidden="true"></div>
      <div class="ls-node-label">
        <span class="ls-node-id">02</span>
        <span class="ls-node-name">KAGEMI</span>
      </div>
    </button>

    <div class="ls-chevron" aria-hidden="true">»</div>

    <!-- Node: SHOT 03 -->
    <button class="ls-node" role="tab" aria-selected="false" data-line="03" data-name="KAGEMI" data-sub="LINE 01 / STORE CONCEPT / SS26" data-img="{{ 'Shinsei Line Store Concept.png' | asset_url }}" data-hero="{{ 'Shinsei Line Store Concept.png' | asset_url }}" data-hero-mobile="{{ 'Shinsei Line Store Concept.png' | asset_url }}">
      <div class="ls-node-dot" aria-hidden="true"></div>
      <div class="ls-node-label">
        <span class="ls-node-id">03</span>
        <span class="ls-node-name">KAGEMI</span>
      </div>
    </button>

  </div>
</div><!-- /.line-selector -->

<!-- PRODUCT LINES -->
<section class="featured-product product-lines-section">
  <div class="product-lines-inner">

    <div class="lines-header">
      <span class="lines-header-label">CURRENT LINES</span>
      <span class="lines-header-status">01 ACTIVE</span>
    </div>

    <div class="lines-grid">

      <!-- CARD 1 — LINE 01 ACTIVE -->
      {%- assign kagemi = all_products['kagemi'] -%}
      {%- assign kagemi_url = kagemi.url | default: '/products/kagemi' -%}
      <div class="line-card line-card--active">
        <a href="{{ kagemi_url }}?img={{ 'kagemi mockup.png' | asset_url | url_encode }}" class="line-card-media card-gallery" data-current="0" style="display:block;" data-product-image="{{ 'kagemi mockup.png' | asset_url }}">
          <img src="{{ 'kagemi mockup.png' | asset_url }}" alt="Kagemi — The Structured Overcoat" class="line-card-img card-gallery-img card-gallery-img--active" draggable="false">
          <img src="{{ 'Gemini_Generated_Image_wum8wwum8wwum8ww.png' | asset_url }}" alt="Kagemi — Detail" class="line-card-img card-gallery-img" draggable="false">
          <div class="card-gallery-track" aria-hidden="true">
            <div class="card-gallery-rail">
              <div class="card-gallery-node card-gallery-node--active" data-index="0"></div>
              <div class="card-gallery-node" data-index="1"></div>
            </div>
          </div>
        </a>
        <div class="line-card-body">
          <div class="line-card-body-meta">
            <span class="line-card-name">Kagemi</span>
            <span class="line-card-price">{% if kagemi.price %}{{ kagemi.price | money }}{% else %}$485.00{% endif %}</span>
          </div>
          <a href="{{ kagemi_url }}?img={{ 'kagemi mockup.png' | asset_url | url_encode }}" class="line-card-cta">VIEW NOW</a>
        </div>
      </div>

      <!-- CARD 2 — LINE 02 -->
      <div class="line-card line-card--upcoming">
        <a href="/products/kagemi?available=false" class="line-card-media" style="display:block;"></a>
        <div class="line-card-body">
          <div class="line-card-body-meta">
            <span class="line-card-name">———</span>
            <span class="line-card-price">$—</span>
          </div>
          <a href="/products/kagemi?available=false" class="line-card-cta line-card-cta--disabled">PREVIEW</a>
        </div>
      </div>

      <!-- CARD 3 — LINE 03 -->
      <div class="line-card line-card--locked">
        <a href="/products/kagemi?available=soldout" class="line-card-media" style="display:flex; min-height:300px;"></a>
        <div class="line-card-body">
          <div class="line-card-body-meta">
            <span class="line-card-name">———</span>
            <span class="line-card-price">$—</span>
          </div>
          <a href="/products/kagemi?available=soldout" class="line-card-cta line-card-cta--disabled">PREVIEW</a>
        </div>
      </div>

    </div><!-- /.lines-grid -->
  </div>
</section>

{% schema %}
{
  "name": "Home",
  "settings": []
}
{% endschema %}
