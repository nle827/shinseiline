{% comment %}
  Shinsei Line Password Page Template
  
  A brand-focused holding page with only the wordmark displayed.
  The Shopify password form is hidden (display: none) since this serves
  as a pure holding page.
  
  Design tokens applied:
  - Background: #FAFAFA (primary background)
  - Logo: SHINSEI_LINE_LOGO_PNG-01.png
  - Responsive layout: 100vh viewport, centered
  
  https://shopify.dev/docs/storefronts/themes/architecture/templates/password
{% endcomment %}

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scan {
    0% {
      left: -100%;
    }
    50% {
      left: 100%;
    }
    100% {
      left: -100%;
    }
  }

  @keyframes pulse {
    0%, 100% {
      background: #2e2e2e;
    }
    50% {
      background: #5a5a5a;
    }
  }

  /* Hide all default Shopify password forms */
  html, body {
    background-color: #FAFAFA !important;
    overflow: hidden !important;
  }

  body * {
    display: none !important;
  }

  /* Show only our custom password page */
  .password-page-wrapper {
    display: flex !important;
  }

  .password-page-wrapper,
  .password-page-wrapper * {
    display: inherit !important;
  }

  .password-page-wrapper {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #FAFAFA;
    z-index: 99999;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .password-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  .password-wordmark {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    animation: fadeIn 1.8s ease forwards;
    animation-delay: 0.4s;
    opacity: 0;
  }

  .password-wordmark img {
    width: auto;
    height: 64px;
    display: block;
  }



  .year-tag {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 10px;
    animation: fadeIn 1.8s ease forwards;
    animation-delay: 1.4s;
    opacity: 0;
  }

  .year-tag-rule {
    width: 40px;
    height: 2px;
    background-color: #2a2a2a;
    position: relative;
    overflow: hidden;
  }

  .year-tag-rule::after {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 2px;
    background: #5a5a5a;
    animation: scan 3.2s ease-in-out infinite;
    animation-delay: 2.4s;
    content: '';
  }

  .dot-group {
    display: flex;
    flex-direction: row;
    gap: 5px;
    align-items: center;
  }

  .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #2e2e2e;
    animation: pulse 2.4s ease-in-out infinite;
  }

  .dot:nth-child(1) {
    animation-delay: 2.6s;
  }

  .dot:nth-child(2) {
    animation-delay: 2.9s;
  }

  .dot:nth-child(3) {
    animation-delay: 3.2s;
  }

  .year-text {
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #3a3a3a;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    line-height: 1;
  }

  @media (max-width: 640px) {
    .password-wordmark img {
      height: 48px;
    }
    .year-tag-rule {
      width: 32px;
    }
    .year-text {
      font-size: 11px;
    }
  }

  @media (max-width: 480px) {
    .password-wordmark img {
      height: 40px;
    }
    .year-tag {
      gap: 8px;
    }
    .year-tag-rule {
      width: 24px;
    }
    .dot {
      width: 3px;
      height: 3px;
    }
    .year-text {
      font-size: 10px;
    }
  }

  {% comment %} Hide the default Shopify password form {% endcomment %}
  .shopify-challenge__container {
    display: none !important;
  }
</style>

<div class="password-page-wrapper">
  <div class="password-content">
    <div class="password-wordmark">
      <img 
        src="{{ 'SHINSEI_LINE_LOGO_PNG-01.png' | asset_url }}" 
        alt="Shinsei Line" 
        width="auto" 
        height="64"
      >
    </div>

    <div class="year-tag">
      <div class="year-tag-rule"></div>
      <div class="dot-group">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
      <div class="year-text">2026</div>
      <div class="dot-group">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
      <div class="year-tag-rule"></div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
