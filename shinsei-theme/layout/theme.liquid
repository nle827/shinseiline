<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — Shinsei Line</title>

  {% render 'meta-tags' %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;1,400&family=Space+Mono:wght@400&display=swap">

  {{ 'shinsei-preview.css' | asset_url | stylesheet_tag }}
  {{ 'shinsei-home.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>
<body class="{% if request.page_type == 'index' %}home-page{% elsif request.page_type == 'product' %}home-page pdp-page{% endif %}">

  <!-- HEADER -->
  <header class="site-header">
    <div class="header-inner">
      <nav class="header-nav">
        <a href="{{ routes.root_url }}" class="nav-link{% if request.page_type == 'index' %} active{% endif %}">Home</a>
        <a href="/pages/about" class="nav-link{% if request.path == '/pages/about' %} active{% endif %}">About</a>
        <a href="{{ routes.all_products_collection_url }}" class="nav-link{% if request.page_type == 'collection' %} active{% endif %}">Shop</a>
        <a href="/pages/contact" class="nav-link{% if request.path == '/pages/contact' %} active{% endif %}">Contact</a>
      </nav>
      <button class="hamburger-btn" aria-label="Menu" aria-expanded="false" onclick="toggleMobileNav()">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <a href="{{ routes.root_url }}" class="header-logo">
        <img src="{{ 'SHINSEI_LINE_LOGO_PNG-01.png' | asset_url }}" alt="Shinsei Line" class="logo-img">
      </a>
      <div class="header-actions">
        <button class="search-trigger" aria-label="Search" onclick="toggleSearch()">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6.5" cy="6.5" r="5"/><line x1="10.5" y1="10.5" x2="15" y2="15"/></svg>
        </button>
        <button class="cart-trigger" onclick="toggleCart()">Cart <span class="cart-count">{% if cart.item_count > 0 %}{{ cart.item_count }}{% endif %}</span></button>
      </div>
    </div>
    <div class="header-line-stripe" aria-hidden="true"></div>
  </header>

  <!-- MOBILE NAV OVERLAY -->
  <div class="mobile-nav-overlay" id="mobile-nav" aria-hidden="true">
    <nav class="mobile-nav-links">
      <a href="{{ routes.root_url }}" class="mobile-nav-link{% if request.page_type == 'index' %} active{% endif %}" onclick="toggleMobileNav()">Home</a>
      <a href="/pages/about" class="mobile-nav-link{% if request.path == '/pages/about' %} active{% endif %}" onclick="toggleMobileNav()">About</a>
      <a href="{{ routes.all_products_collection_url }}" class="mobile-nav-link{% if request.page_type == 'collection' %} active{% endif %}" onclick="toggleMobileNav()">Shop</a>
      <a href="/pages/contact" class="mobile-nav-link{% if request.path == '/pages/contact' %} active{% endif %}" onclick="toggleMobileNav()">Contact</a>
    </nav>
  </div>

  <main id="main-content">
    {{ content_for_layout }}
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-inner">
      <nav class="footer-nav">
        <a href="{{ routes.root_url }}">Home</a>
        <a href="/pages/policy">Policy</a>
        <a href="/pages/about">About</a>
        <a href="/pages/contact">Contact</a>
      </nav>
      <div class="footer-brand"></div>
      <div class="footer-meta">
        <span>© 2026 Shinsei Line. All rights reserved.</span>
      </div>
    </div>
  </footer>

  <!-- CART DRAWER -->
  <div class="cart-drawer" id="cart-drawer">
    <div class="cart-overlay" onclick="toggleCart()"></div>
    <div class="cart-panel">
      <div class="cart-panel-header">
        <span class="cart-panel-title">CART</span>
        <button class="cart-close" onclick="toggleCart()">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="1.5"/><line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="1.5"/></svg>
        </button>
      </div>
      <div class="cart-panel-body" id="cart-body">
        <div class="cart-empty">
          <p>YOUR CART IS EMPTY</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn cart-browse-btn">BROWSE LINES</a>
        </div>
      </div>
    </div>
  </div>

  <!-- SEARCH OVERLAY -->
  <div class="search-overlay" id="search-overlay">
    <button class="search-overlay-close" onclick="toggleSearch()">Close</button>
    <div class="search-overlay-inner">
      <form class="search-overlay-form" action="{{ routes.search_url }}" method="get">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6.5" cy="6.5" r="5"/><line x1="10.5" y1="10.5" x2="15" y2="15"/></svg>
        <input type="text" name="q" id="search-overlay-input" placeholder="Search products..." autocomplete="off">
        <button type="submit" aria-label="Submit search">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="0" y1="7" x2="13" y2="7"/><polyline points="7,1 13,7 7,13"/></svg>
        </button>
      </form>
    </div>
  </div>

  {{ 'shinsei-preview.js' | asset_url | script_tag }}
  {% if request.page_type == 'index' or request.page_type == 'product' %}
    {{ 'shinsei-home.js' | asset_url | script_tag }}
  {% endif %}

</body>
</html>
